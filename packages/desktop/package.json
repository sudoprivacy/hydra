{
  "name": "@hydra/desktop",
  "version": "0.3.2026071503",
  "description": "Hydra desktop — Electron shell (M1). Main forks the plain-Node sidecar, mints a per-launch bearer token, and hands { url, token } to a React renderer that talks to the sidecar over LoopbackHttpWsTransport.",
  "license": "MIT",
  "private": true,
  "main": "./out/main.js",
  "scripts": {
    "build:main": "tsc -b tsconfig.json",
    "typecheck:renderer": "tsc -p tsconfig.renderer.json",
    "build:renderer": "node scripts/build-frontend.mjs",
    "build": "npm run build:main && npm run typecheck:renderer && npm run build:renderer",
    "start": "electron out/main.js",
    "boot-check": "node out/bootCheck.js",
    "smoke:diff": "node out/smoke/diffModelSmoke.js",
    "smoke:auto-update": "node out/smoke/autoUpdateSmoke.js",
    "smoke:release-config": "node scripts/releaseConfigurationSmoke.mjs",
    "pack:mac": "npm run build && electron-builder --mac --dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:mac:release": "node scripts/dist-mac-release.mjs",
    "dist:mac:release:resume": "node scripts/dist-mac-release.mjs --resume"
  },
  "dependencies": {
    "@hydra/protocol": "*",
    "@hydra/sidecar": "*",
    "@hydra/transport-loopback": "*",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@hydra/core": "*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.0"
  },
  "build": {
    "appId": "com.sudoprivacy.hydra",
    "productName": "Hydra",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "build/app-update.yml",
        "to": "app-update.yml"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "sudoprivacy",
        "repo": "hydra"
      }
    ],
    "asar": false,
    "npmRebuild": false,
    "electronVersion": "33.4.11",
    "files": [
      "out/**/*",
      "assets/**/*",
      "index.html",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        },
        {
          "target": "zip",
          "arch": "arm64"
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false
    }
  }
}
